# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
.uv/

# Environment — NEVER commit real .env
.env
.env.local
.env.*.local
!.env.example

# Logs — belt-and-suspenders; prevent log files from reaching git
*.log

# Testing & coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# Playwright auth state — contains real session cookies; never commit
frontend/playwright/.auth/
frontend/playwright-report/

# Compiled SPA — generated by `npm run build` (Vite writes to app/static/spa/).
# Built during Docker multi-stage build; never committed to git.
# Run `cd frontend && npm run build` locally before starting the backend.
app/static/spa/

# Docker
*.dockerignore

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# ============================================================
# Espresso Logs — Environment Variables
# Copy this file to .env and fill in your own values.
# Never commit .env to git.
# ============================================================

# ── Data store ─────────────────────────────────────────────
# Your Google Sheets spreadsheet ID (the long ID in the sheet URL).
# deprecated — remove at M6 when Postgres migration is complete
SPREADSHEET_ID=YOUR_SPREADSHEET_ID_HERE

# ── Session security ────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be at least 32 characters. Required in production.
SESSION_SECRET=generate-with-openssl-rand-hex-32

# ── Google OAuth ────────────────────────────────────────────
# Create OAuth 2.0 credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET

# Redirect URI — must exactly match what is registered in Google Cloud Console
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Email allowlist ─────────────────────────────────────────
# Comma-separated list of email addresses allowed to log in
ALLOWLIST_EMAILS=you@example.com,colleague@example.com

# ── AI providers ────────────────────────────────────────────
# Anthropic API key — primary AI provider
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Gemini fallback key — used when Anthropic is unavailable (optional)
# https://aistudio.google.com/app/apikey
LLM_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── GCP project (optional — auto-detected on Cloud Run) ─────
# Set explicitly for local dev if you need GCS image uploads.
# The GCS bucket is inferred as: {GCP_PROJECT_ID}-assets
# Leave unset if you do not need image upload functionality locally.
# GCP_PROJECT_ID=your-gcp-project-id

# ── Cloud Run secret blob (do not set locally) ──────────────
# APP_SECRETS is a JSON blob injected by Cloud Run via Secret Manager.
# On local dev, set individual env vars above instead.
# APP_SECRETS={"SESSION_SECRET":"...","GOOGLE_OAUTH_CLIENT_ID":"..."}

# ── App runtime ─────────────────────────────────────────────
# Server port — Cloud Run injects PORT automatically; leave 8080 for local dev
PORT=8080

# Application environment: development or production
APP_ENV=development

# v2.0 — not yet active (will be required after Postgres migration M6)
# DATABASE_URL=postgresql://user:password@localhost:5432/espresso_logs
# JWT_SECRET=generate-with-openssl-rand-hex-32
